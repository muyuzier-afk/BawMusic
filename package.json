{
  "name": "music-player",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23",
    "npm": ">=10"
  },
  "scripts": {
    "predev": "node scripts/build-info.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/build-info.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "node scripts/patch-capacitor-java17.js",
    "cap:sync": "npm run build && npx cap sync",
    "cap:add:android": "npm run build && npx cap add android",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@applemusic-like-lyrics/react": "^0.5.2",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/status-bar": "^8.0.2",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/filter-blur": "^7.4.3",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/sprite": "^7.4.3",
    "capacitor-music-controls-plugin": "^6.1.0",
    "jss": "^10.10.0",
    "jss-preset-default": "^10.10.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prettier": "^3.3.3",
    "typescript": "^5"
  }
}
