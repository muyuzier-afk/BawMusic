+
+/* Playlist toolbar for desktop */
+.playlist-toolbar {
+  display: flex;
+  align-items: center;
+  padding: 10px 20px;
+  border-bottom: 1px solid var(--color-border);
+  gap: 10px;
+}
+
+.playlist-toolbar-actions {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  width: 100%;
+}
+
+.playlist-toolbar-confirm {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  width: 100%;
+}
+
+.playlist-toolbar-text {
+  font-size: 14px;
+  color: var(--color-text-secondary);
+  flex: 1;
+}
+
+.playlist-toolbar-btn {
+  display: inline-flex;
+  align-items: center;
+  gap: 6px;
+  padding: 6px 12px;
+  border-radius: var(--radius-sm);
+  border: 1px solid var(--color-border);
+  background: rgba(255, 255, 255, 0.08);
+  color: var(--color-text);
+  font-size: 13px;
+  cursor: pointer;
+  transition: all var(--transition-fast);
+  white-space: nowrap;
+}
+
+.playlist-toolbar-btn:hover {
+  background: var(--color-surface-hover);
+}
+
+.playlist-toolbar-btn-danger {
+  background: rgba(206, 57, 57, 0.72);
+  border-color: rgba(206, 57, 57, 0.5);
+}
+
+.playlist-toolbar-btn-danger:hover {
+  background: rgba(232, 42, 42, 0.88);
+}
+
+/* Playlist checkbox */
+.playlist-checkbox {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  width: 18px;
+  height: 18px;
+  border-radius: 4px;
+  border: 1.5px solid var(--color-text-tertiary);
+  background: transparent;
+  color: var(--color-text);
+  cursor: pointer;
+  padding: 0;
+  flex-shrink: 0;
+  transition: all var(--transition-fast);
+}
+
+.playlist-checkbox:hover {
+  border-color: var(--color-text-secondary);
+}
+
+.playlist-checkbox.checked {
+  background: var(--color-text);
+  border-color: var(--color-text);
+  color: var(--color-bg);
+}
+
+/* Download button */
+.control-btn-download {
+  width: 38px;
+  height: 38px;
+  padding: 0;
+  border-radius: 50%;
+  border: 1px solid var(--color-border);
+  background: rgba(255, 255, 255, 0.07);
+}
